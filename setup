#!/usr/bin/env bash
set -euo pipefail
shopt -s nocasematch 2>/dev/null || true

# A Player Loops — Setup Script
# Registers all brains as Claude Code slash commands via directory symlinks.
# Idempotent — safe to run multiple times.

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
BRAINS_DIR="$SCRIPT_DIR/brains"
SKILLS_DIR="${HOME}/.claude/skills"

# The brains to register
BRAINS=(
  loops
  significance
  throughline
  loop-design
  signal
  orient
  values
  wins
  update
)

echo ""
echo "  A Player Loops — Setup"
echo "  ======================"
echo ""

# --- Create directories if needed ---

if ! mkdir -p "$SKILLS_DIR" 2>/dev/null; then
  echo "  ERROR: Could not create $SKILLS_DIR — check permissions."
  exit 1
fi

# --- Cleanup old symlinks ---
# Remove any symlink in ~/.claude/skills/ that points into our repo.

echo "  Cleaning up old symlinks..."
CLEANED=0
for entry in "$SKILLS_DIR"/*/; do
  [ -d "$entry" ] || continue
  entry="${entry%/}"

  if [ -L "$entry" ]; then
    target="$(readlink "$entry" 2>/dev/null || true)"
    if [[ "$target" == "$BRAINS_DIR"* ]]; then
      rm "$entry"
      CLEANED=$((CLEANED + 1))
    fi
  fi
done

if [ "$CLEANED" -gt 0 ]; then
  echo "  Removed $CLEANED old symlink(s)."
else
  echo "  No old symlinks found."
fi
echo ""

# --- Create new symlinks ---
# Each brain directory is symlinked as:
#   ~/.claude/skills/{brain-name} → /path/to/repo/brains/{brain-name}

echo "  Registering brains..."
echo ""
REGISTERED=0
FAILED=0

for brain in "${BRAINS[@]}"; do
  source_dir="$BRAINS_DIR/$brain"
  skill_file="$source_dir/SKILL.md"
  link_path="$SKILLS_DIR/$brain"

  if [ ! -d "$source_dir" ]; then
    echo "  SKIP  /$brain — directory not found: $source_dir"
    FAILED=$((FAILED + 1))
    continue
  fi

  if [ ! -f "$skill_file" ]; then
    echo "  SKIP  /$brain — no SKILL.md found"
    FAILED=$((FAILED + 1))
    continue
  fi

  if [ -L "$link_path" ] || [ -e "$link_path" ]; then
    rm -rf "$link_path"
  fi

  if ln -s "$source_dir" "$link_path" 2>/dev/null; then
    echo "  OK    /$brain"
    REGISTERED=$((REGISTERED + 1))
  else
    echo "  FAIL  /$brain — could not create symlink (permissions?)"
    FAILED=$((FAILED + 1))
  fi
done

echo ""
echo "  ---"
echo "  Registered: $REGISTERED brain(s)"
if [ "$FAILED" -gt 0 ]; then
  echo "  Failed:     $FAILED brain(s)"
fi
echo ""

# --- Loop architecture ---
echo "  Loop Architecture Brains"
echo "  ========================"
echo ""
echo "  /loops              → Start here (reads your state, guides you)"
echo ""
echo "  Foundation:"
echo "  /significance       → Define your significant purpose"
echo "  /throughline        → Check if wins point toward purpose"
echo ""
echo "  Design:"
echo "  /loop-design        → Design a single loop (the 5 Jobs)"
echo "  /signal             → Identify what data matters"
echo ""
echo "  Orientation:"
echo "  /orient             → Build agent orientation (5 components)"
echo "  /values             → Inject values into the system"
echo ""
echo "  Operation:"
echo "  /wins               → Evaluate which wins to compound"
echo ""
echo "  Utility:"
echo "  /update             → Get the latest brains"
echo ""
echo "  Type /loops in Claude Code to start."
echo ""
